// ===================== 오행 레이더 차트 (1번) + 막대 그래프 (2번) =====================
function OhengRadar({카운트,용신,전무,과다}){
  var total=Object.values(카운트).reduce(function(a,b){return a+b;},0);
  if(total===0)return null;
  // 오행 순서: 목(상생 순환) 木→火→土→金→水
  var els=['목','화','토','금','수'];
  var cx=120,cy=115,R=75;
  // 오각형 꼭짓점 계산 (12시 방향부터 시계방향)
  function vtx(i,r){var ang=Math.PI*2*i/5 - Math.PI/2;return[cx+r*Math.cos(ang),cy+r*Math.sin(ang)];}
  // 그리드 폴리곤 (3단계, 중심 수렴 제거)
  var grids=[0.5,0.75,1].map(function(s){return els.map(function(_,i){return vtx(i,R*s);}).map(function(p){return p[0]+','+p[1];}).join(' ');});
  // 축선: 0.5R~1R 구간만 (중심 안 지남)
  var axes=els.map(function(_,i){var inner=vtx(i,R*0.5);var outer=vtx(i,R);return 'M'+inner[0]+','+inner[1]+' L'+outer[0]+','+outer[1];});
  // 데이터 폴리곤 — 최대값 기준 정규화
  var maxCnt=Math.max.apply(null,Object.values(카운트));
  if(maxCnt===0)maxCnt=1;
  var nonZeroVals=Object.values(카운트).filter(function(v){return v>=0.05;});
  var minCnt=nonZeroVals.length>0?Math.min.apply(null,nonZeroVals):1;
  var dataPts=els.map(function(oh,i){
    var val=카운트[oh]||0;
    var ratio=val===0?0:Math.max(0.15,val/maxCnt); // 전무는 중심, 나머지는 최소15%
    var p=vtx(i,R*ratio);
    return{x:p[0],y:p[1],oh:oh,cnt:val,pct:total>0?Math.round(val/total*100):0};
  });
  var dataPath=dataPts.map(function(p){return p.x+','+p.y;}).join(' ');

  return React.createElement('div',{style:{animation:'fadeUp 0.6s ease both'}},
    // 레이더 차트 제목
    React.createElement('div',{style:{textAlign:'center',marginBottom:8}},
      React.createElement('span',{style:{fontSize:14,fontWeight:700,color:'#e8d5a8',fontFamily:"'Noto Serif KR',serif"}},'오행 균형 상태')
    ),
    // SVG 레이더
    React.createElement('div',{style:{display:'flex',justifyContent:'center',margin:'0 auto',maxWidth:260}},
      React.createElement('svg',{viewBox:'0 0 240 230',style:{width:'100%',maxWidth:260,height:'auto'}},
        // 그리드 폴리곤
        grids.map(function(pts,gi){
          return React.createElement('polygon',{key:'g'+gi,points:pts,fill:'none',stroke:'rgba(180,140,80,0.1)',strokeWidth:gi===2?1:0.5});
        }),
        // 축선
        axes.map(function(d,ai){
          return React.createElement('path',{key:'a'+ai,d:d,stroke:'rgba(180,140,80,0.06)',strokeWidth:0.5});
        }),
        // 데이터 폴리곤 (그라디언트 필)
        React.createElement('defs',null),
        React.createElement('polygon',{points:dataPath,fill:'rgba(200,168,90,0.12)',stroke:'rgba(200,168,90,0.6)',strokeWidth:1.5,style:{animation:'radarDraw 1s ease both'}}),
        // 데이터 포인트 — 선만 (동그라미 제거)
        // 꼭짓점 라벨 (한자 + 한글)
        els.map(function(oh,i){
          var lp=vtx(i,R+18);
          var c=OH_COLOR_MAP[oh];if(!c)return null;
          var isYongsin=용신===oh;
          var isZero=카운트[oh]===0;
          return React.createElement('g',{key:'lb'+i},
            React.createElement('text',{x:lp[0],y:lp[1]-5,textAnchor:'middle',dominantBaseline:'central',fill:isZero?'#4a4030':c.fg,fontSize:16,fontWeight:700,fontFamily:'serif',opacity:isZero?0.4:1},c.label),
            React.createElement('text',{x:lp[0],y:lp[1]+9,textAnchor:'middle',dominantBaseline:'central',fill:isZero?'#3a3530':'#5a5040',fontSize:8},oh),
            isYongsin&&React.createElement('text',{x:lp[0],y:lp[1]+19,textAnchor:'middle',dominantBaseline:'central',fill:'#ffd700',fontSize:7,fontWeight:600},'용신')
          );
        })
      )
    ),
    // 전무/과다 뱃지
    (전무.length>0||과다.length>0)&&React.createElement('div',{style:{display:'flex',justifyContent:'center',gap:8,marginTop:6,flexWrap:'wrap'}},
      전무.map(function(oh){var c=OH_COLOR_MAP[oh];return React.createElement('span',{key:'z'+oh,style:{fontSize:9,padding:'2px 8px',borderRadius:10,background:'rgba(120,90,72,0.15)',color:'#7a5a48',border:'1px solid rgba(120,90,72,0.2)'}},c?c.label:'','  전무(不及)');}),
      과다.map(function(oh){var c=OH_COLOR_MAP[oh];return React.createElement('span',{key:'e'+oh,style:{fontSize:9,padding:'2px 8px',borderRadius:10,background:'rgba(200,168,90,0.1)',color:'#c8a85a',border:'1px solid rgba(200,168,90,0.15)'}},c?c.label:'','  과다(太過)');})
    ),
    // 오행 프로그레스 바 (#2 항목)
    React.createElement('div',{style:{marginTop:16,padding:'0 8px'}},
      els.map(function(oh,i){
        var cnt=카운트[oh]||0;
        var c=OH_COLOR_MAP[oh];if(!c)return null;
        var isYongsin=용신===oh;
        var isZero=cnt<0.05;
        // 최소값=1 기준 상대값
        var relVal=minCnt>0&&!isZero?Math.round(cnt/minCnt*10)/10:0;
        var barPct=maxCnt>0?Math.round(cnt/maxCnt*100):0;
        return React.createElement('div',{key:'bar'+oh,style:{display:'flex',alignItems:'center',gap:8,marginBottom:6,animation:'fadeUp 0.3s '+(0.1*i)+'s both ease-out'}},
          // 한자 라벨
          React.createElement('div',{style:{width:22,fontSize:14,fontWeight:700,color:isZero?'#3a3530':c.fg,fontFamily:'serif',textAlign:'center',opacity:isZero?0.4:1}},c.label),
          // 한글
          React.createElement('div',{style:{width:24,fontSize:9,color:isZero?'#3a3530':'#5a5040'}},oh),
          // 프로그레스 바
          React.createElement('div',{style:{flex:1,height:8,background:'rgba(180,140,80,0.06)',borderRadius:4,overflow:'hidden',position:'relative'}},
            React.createElement('div',{style:{width:barPct+'%',height:'100%',background:isZero?'transparent':'linear-gradient(90deg,'+c.fg+'88,'+c.fg+')',borderRadius:4,transition:'width 0.8s ease',minWidth:isZero?0:2}}),
            isYongsin&&React.createElement('div',{style:{position:'absolute',top:-1,left:0,right:0,bottom:-1,border:'1px solid #ffd70044',borderRadius:4}})
          ),
          // 상대값 (최소=1)
          React.createElement('div',{style:{width:28,textAlign:'right',fontSize:11,fontWeight:700,color:isZero?'#3a3530':c.fg,opacity:isZero?0.4:1}},isZero?'-':relVal)
        );
      })
    ),
    // 균형 상태 한줄 요약
    React.createElement('div',{style:{textAlign:'center',fontSize:10,color:'#6a5e4d',marginTop:8,padding:'6px 12px',background:'rgba(180,140,80,0.03)',borderRadius:8,border:'1px solid rgba(180,140,80,0.06)'}},
      전무.length>0?전무.map(function(oh){return OH_COLOR_MAP[oh]?OH_COLOR_MAP[oh].label:'';}).join('·')+' 기운이 부족하니, 용신('+OH_COLOR_MAP[용신||'목'].label+')으로 보완하면 좋겠네.'
      :과다.length>0?과다.map(function(oh){return OH_COLOR_MAP[oh]?OH_COLOR_MAP[oh].label:'';}).join('·')+' 기운이 넘치니 조절이 필요하겠네.'
      :'오행이 비교적 고르게 분포되어 있네. 균형 잡힌 사주일세.'
    )
  );
}
