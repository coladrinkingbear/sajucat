// ── 고양이 한줄 코멘트 생성 ──
function generateCatComment(result,category){
  var ss=result.십성,강약=result.강약,용신=result.용신;
  if(category==='성격'){
    if(ss.비견>=2&&ss.겁재>=1)return '자네는 비견·겁재가 강하니 자기 주장이 확실하고 경쟁심이 넘치네. 다만 남의 말을 듣는 귀도 키워야 하네.';
    if(ss.편인>=2)return '편인이 강해서 독특한 사고방식을 가졌네. 남들이 가지 않는 길에서 빛을 발할 타입이네.';
    if(ss.정관>=1&&ss.정인>=1)return '관인상생(官印相生)의 구조라 체계적이고 논리적인 성격이네. 조직 생활에 강하네.';
    if(ss.상관>=2)return '상관이 강해서 자유로운 영혼이네. 규율보다 창의성으로 승부하는 타입이지.';
    if(ss.식신>=1&&ss.정재>=1)return '식신생재(食神生財)의 구조라 재능을 돈으로 연결하는 능력이 있네. 실리적인 성격이네.';
    return 강약==='신강'?'기운이 넘치는 사주라 자신감이 강하네. 이 에너지를 잘 쓰면 큰 성취가 가능하네.':'기운이 약한 편이라 환경에 민감하지만, 그만큼 눈치와 공감 능력이 뛰어나네.';
  }
  if(category==='건강'){
    var 오행=result.오행;
    if(오행.전무&&오행.전무.length>0)return 오행.전무.join('·')+' 오행이 부족하니 해당 장기를 특히 살펴야 하네. 용신 '+용신+'을 보강하면 건강에도 도움이 되네.';
    return 강약==='신강'?'넘치는 기운 탓에 과로하기 쉬우니, 일부러 쉬는 시간을 만들어야 하네.':'기운이 약하니 무리하지 말고 규칙적인 생활로 에너지를 관리하게.';
  }
  if(category==='아버지'){
    var 재=ss.편재+ss.정재;
    if(재===0)return '재성이 사주에 없어서 아버지와 일찍 떨어지거나 교류가 적을 수 있네.';
    if(재>=2)return '재성이 풍부해서 아버지의 도움을 받을 복이 있네.';
    return '아버지 인연이 보통 정도이네.';
  }
  if(category==='어머니'){
    var 인=ss.편인+ss.정인;
    if(인===0)return '인성이 없어서 어머니의 돌봄이 부족했을 수 있네. 자수성가형이네.';
    if(인>=2)return '인성이 풍부해서 어머니의 사랑을 많이 받은 명식이네.';
    return '어머니 인연이 보통 정도이네.';
  }
  if(category==='배우자'){
    var 배=result.saju.gender==='남'?(ss.정재+ss.편재):(ss.정관+ss.편관);
    if(배===0)return '배우자 해당 십성이 없으니 만혼이거나 인연이 늦을 수 있네. 대운에서 올 때를 기다리게.';
    if(배>=2)return '배우자 십성이 강하니 이성 인연이 풍부하네. 다만 선택의 갈등이 있을 수 있네.';
    return '배우자 인연이 적당하네. 일지의 상태가 핵심이네.';
  }
  if(category==='자식'){
    var 식=ss.식신+ss.상관;
    if(식===0)return '식상이 없으니 자녀 인연이 약하거나 늦을 수 있네.';
    if(ss.편인>=2&&식>=1)return '편인이 식신을 극하는 도식(倒食) 구조가 있으니 자녀 양육에 각별한 주의가 필요하네.';
    return '식상이 있으니 자녀 인연은 있네.';
  }
  if(category==='재물'){
    if(ss.정재+ss.편재===0)return '재성이 사주에 없으니 돈보다 명예나 학문을 추구하는 성정이네. 대운에서 재성이 올 때 기회를 잡아야 하네.';
    if(ss.겁재>=2&&ss.편재>=1)return '편재가 있으나 겁재가 극하니 투자 손실이나 보증 사고를 특히 조심해야 하네.';
    if(강약==='신강'&&ss.편재>=1)return '일간이 강하고 편재가 있으니 큰 재물을 다룰 그릇이 되네. 사업이나 투자에서 성과를 낼 수 있네.';
    if(강약==='신약'&&(ss.정재+ss.편재)>=2)return '재다신약(財多身弱)의 기운이 있네. 돈은 보이는데 잡기 어려우니, 용신이 오는 대운에서 승부해야 하네.';
    return '재물운이 보통이네. 용신 '+용신+'의 시기에 재물운이 올라가네.';
  }
  if(category==='직장'){
    if(ss.상관>=1&&ss.정관>=1)return '상관견관(傷官見官)의 구조라 상사와 충돌하기 쉽네. 자유업이나 전문직이 맞을 수 있네.';
    if(ss.정관>=1)return '정관이 있으니 조직 안에서 인정받고 승진하는 흐름이 있네.';
    if(ss.편관>=2)return '편관이 강해 외부 압박이 세지만, 이를 극복하면 큰 권력을 얻을 수 있네.';
    return '관성이 약하니 조직보다 자율적인 환경이 잘 맞을 수 있네.';
  }
  if(category==='학문'){
    if(ss.정인>=1&&ss.편인>=1)return '정인과 편인이 모두 있으니 정통 학문과 비정통 분야 모두 소화할 수 있는 넓은 지식의 소유자이네.';
    if(ss.편인>=2)return '편인이 강해 독창적인 연구나 특수 분야에서 두각을 나타낼 명식이네.';
    if(ss.정인>=1)return '정인이 있으니 시험이나 자격증에 강하고, 학문적 성취가 있을 명식이네.';
    return '인성이 약하니 독학이나 현장 경험으로 실력을 쌓는 타입이네.';
  }
  return '';
}

