        <CatFace size={120}/>
      </div>

      {/* 대사 1 */}
      {catNavStep>=2&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:20,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block',position:'relative'}}>
            <div style={{position:'absolute',top:-7,left:'50%',marginLeft:-7,width:0,height:0,borderLeft:'7px solid transparent',borderRight:'7px solid transparent',borderBottom:'7px solid rgba(180,140,80,0.12)'}}/>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>다 봤는가?</p>
          </div>
        </div>
      )}

      {/* 대사 2 */}
      {catNavStep>=3&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:10,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block'}}>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>스승님의 실력은 자네도 잘 봤겠지.</p>
          </div>
        </div>
      )}

      {/* 대사 3 */}
      {catNavStep>=4&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:10,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block'}}>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>마침 스승님께서 자네에게 관심이 있어<br/>원한다면 더 대화를 할 수 있네.</p>
          </div>
        </div>
      )}

      {/* 대사 4 */}
      {catNavStep>=5&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:10,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block'}}>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>아니면 우리 신당에서 주선하는<br/>인연채팅을 이용할 수도 있지.</p>
          </div>
        </div>
      )}

      {/* 비로그인: 로그인 유도 — 대사 + 예/아니오 */}
      {catNavStep>=6&&!authUser&&!catNavLoading&&catNavStep<8&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:10,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block'}}>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>다만 이 부분을 이용하려면<br/>로그인을 해야하네. 로그인할 텐가?</p>
          </div>
          {catNavStep===6&&(
            <div style={{marginTop:16,display:'flex',gap:10,justifyContent:'center'}}>
              <button onClick={function(){setCatNavStep(7);}} style={{padding:'10px 32px',background:'transparent',border:'1px solid rgba(180,140,80,0.25)',borderRadius:10,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer'}}>예</button>
              <button onClick={function(){setCatNavStep(8);}} style={{padding:'10px 32px',background:'transparent',border:'1px solid rgba(180,140,80,0.1)',borderRadius:10,fontSize:13,fontWeight:400,color:'#7a7060',cursor:'pointer'}}>아니오</button>
            </div>
          )}
        </div>
      )}

      {/* 비로그인: '예' → 로그인 화면 (첫 화면 스타일) */}
      {catNavStep===7&&!authUser&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:16,textAlign:'center',width:'100%',maxWidth:300}}>
          <div style={{display:'flex',flexDirection:'column',gap:10}}>
            <button onClick={function(){window.location.href='/auth/kakao';}} style={{width:'100%',padding:'13px',background:'#FEE500',border:'none',borderRadius:12,fontSize:14,fontWeight:700,color:'#3C1E1E',cursor:'pointer',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
              <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#3C1E1E" d="M9 1C4.58 1 1 3.79 1 7.21c0 2.17 1.45 4.08 3.63 5.18l-.93 3.42c-.08.29.25.52.5.35L8 13.55c.33.03.66.05 1 .05 4.42 0 8-2.79 8-6.21S13.42 1 9 1z"/></svg>
              카카오로 시작하기
            </button>
            <button onClick={function(){window.location.href='/auth/google';}} style={{width:'100%',padding:'13px',background:'#fff',border:'1px solid #ddd',borderRadius:12,fontSize:14,fontWeight:700,color:'#333',cursor:'pointer',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
              <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2a10.4 10.4 0 0 0-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92A8.78 8.78 0 0 0 17.64 9.2z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.91-2.26a5.4 5.4 0 0 1-8.09-2.84H.96v2.33A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.96 10.71a5.4 5.4 0 0 1 0-3.42V4.96H.96a9 9 0 0 0 0 8.08l3-2.33z"/><path fill="#EA4335" d="M9 3.58a4.86 4.86 0 0 1 3.44 1.35l2.58-2.59A8.65 8.65 0 0 0 9 0 9 9 0 0 0 .96 4.96l3 2.33A5.36 5.36 0 0 1 9 3.58z"/></svg>
              구글로 시작하기
            </button>
          </div>
          <button onClick={function(){setCatNavStep(8);}} style={{marginTop:12,background:'transparent',border:'none',fontSize:11,color:'#5a5040',cursor:'pointer'}}>← 돌아가기</button>
        </div>
      )}

      {/* 비로그인: '아니오' → 2개 선택지 */}
      {catNavStep>=8&&!authUser&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:16,width:'100%',maxWidth:320,display:'flex',flexDirection:'column',gap:8}}>
          <button onClick={function(){setCatNavLoading('result');setTimeout(function(){setCatNavLoading(null);setResultTab(0);setPhase('result');},1200);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.15)',borderRadius:12,fontSize:13,fontWeight:500,color:'#c0b8a0',cursor:'pointer',textAlign:'center'}}>📋 내 사주 다시보기</button>
          <button onClick={function(){setCatNavLoading('new');setTimeout(function(){setCatNavLoading(null);setPhase('intro');setIntroStep(0);setResult(null);setPremium(null);setAiCache({});setDialogStep(0);setDialogMsgs([]);setResultTab(0);},1200);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.1)',borderRadius:12,fontSize:13,fontWeight:400,color:'#7a7060',cursor:'pointer',textAlign:'center'}}>🔄 다른 사주 보기</button>
        </div>
      )}

      {/* 로딩 상태 */}
      {catNavLoading&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:20,textAlign:'center'}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'12px 20px',display:'inline-block',position:'relative'}}>
            <div style={{position:'absolute',top:-7,left:'50%',marginLeft:-7,width:0,height:0,borderLeft:'7px solid transparent',borderRight:'7px solid transparent',borderBottom:'7px solid rgba(180,140,80,0.12)'}}/>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>{catNavLoading==='mansin'?'스승님한테 안내해주겠네.':catNavLoading==='yeonin'?'좋은 인연을 찾아보겠네.':catNavLoading==='result'?'무료 결과로 돌아가겠네.':'새로운 사주를 봐주겠네.'}</p>
          </div>
<div style={{marginTop:16,animation:'shimmer 1s infinite'}}><CatFace size={36}/></div>
        </div>
      )}

      {/* 선택지 — 로그인 사용자: 4개 */}
      {authUser&&catNavStep>=6&&!catNavLoading&&(
        <div style={{animation:'fadeUp 0.6s ease',marginTop:20,width:'100%',maxWidth:320,display:'flex',flexDirection:'column',gap:8}}>
          <button onClick={function(){setCatNavLoading('mansin');setTimeout(function(){setCatNavLoading(null);startMansinChat();},1400);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.2)',borderRadius:12,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer',textAlign:'center',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
            <span style={{fontFamily:'serif',fontSize:15,color:'#8a7e6d'}}>巫</span> 바리만신과 대화하기
          </button>
          <button onClick={function(){setCatNavLoading('yeonin');setTimeout(function(){setCatNavLoading(null);trackAct('yeonin_start');var ym=getYeoninMatches(result.일간,form.gender);setYeoninMatches(ym);setPhase('matches');},1400);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.2)',borderRadius:12,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer',textAlign:'center',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
            <span style={{fontFamily:'serif',fontSize:15,color:'#8a7e6d'}}>緣</span> 인연 찾기
          </button>
          <button onClick={function(){setCatNavLoading('result');setTimeout(function(){setCatNavLoading(null);setResultTab(0);setPhase('result');},1200);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.2)',borderRadius:12,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer',textAlign:'center',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
            <span style={{fontFamily:'serif',fontSize:15,color:'#8a7e6d'}}>卦</span> 무료 사주 결과
          </button>
          <button onClick={function(){setCatNavLoading('new');setTimeout(function(){setCatNavLoading(null);setPhase('intro');setIntroStep(0);setResult(null);setPremium(null);setAiCache({});setDialogStep(0);setDialogMsgs([]);setResultTab(0);setCalligPlayed(false);},1200);}} style={{width:'100%',padding:'13px 18px',background:'transparent',border:'1px solid rgba(180,140,80,0.2)',borderRadius:12,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer',textAlign:'center',display:'flex',alignItems:'center',justifyContent:'center',gap:8}}>
            <span style={{fontFamily:'serif',fontSize:15,color:'#8a7e6d'}}>新</span> 다른 사주 보기
          </button>
        </div>
      )}

      <style>{'svg{border:none!important;outline:none!important;box-shadow:none!important}@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}@keyframes float1{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}@keyframes float2{0%,100%{transform:translateY(0) translateX(0)}50%{transform:translateY(-15px) translateX(8px)}}@keyframes shimmer{0%{opacity:0.4}50%{opacity:0.8}100%{opacity:0.4}}'}</style>
    </div>
  );

  // ============================================================
  // 인연찾기 — 프로필 선택 화면
  // ============================================================
  if(phase==='matches')return(
    <div style={{minHeight:'100vh',background:'radial-gradient(ellipse at 50% 15%,#1a1028,#0e0a18)',color:'#e8d5a8',fontFamily:"'Noto Sans KR',sans-serif",padding:'20px 16px 60px',maxWidth:440,margin:'0 auto'}}>
      <div style={{textAlign:'center',marginBottom:20}}>
        <BariMansin size={50}/>
        <h2 style={{fontSize:16,fontWeight:700,fontFamily:"'Noto Serif KR',serif",margin:'8px 0'}}><span style={{background:'linear-gradient(135deg,#d0b0ff,#8060c0)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent'}}>바리만신이 점지한 인연</span></h2>
        <p style={{fontSize:11,color:'#8070a0'}}>{result.일간}{result.일지}일주({form.gender})에게 어울리는 인연 3명</p>
      </div>

      {yeoninMatches.map(function(u,i){
        var gc=i===0?'#d0a0ff':i===1?'#a0c0ff':'#f0b0c0';
        var rankLabel=i===0?'💜 천생연분':i===1?'💙 편안한 인연':'💗 설레는 인연';
        return(
          <div key={u.key} style={{background:'rgba(160,120,200,0.04)',border:'1px solid rgba(160,120,200,0.12)',borderRadius:16,padding:'16px',marginBottom:12,cursor:'pointer',transition:'all 0.2s'}} onClick={function(){setChatTarget(u);setChatMsgs(function(prev){var k=u.key;if(!prev[k]||prev[k].length===0){var g={from:u.key,text:'안녕하세요! 궁합이 좋다고 해서 기대하고 있었어요 ㅎㅎ',time:'',role:'assistant',content:''};var n=Object.assign({},prev);n[k]=[g];return n;}return prev;});setPhase('chat');}}>
            <div style={{display:'flex',alignItems:'center',gap:4,marginBottom:10}}>
              <span style={{fontSize:11,fontWeight:700,color:gc}}>{rankLabel}</span>
              <span style={{marginLeft:'auto',fontSize:20,fontWeight:800,color:gc}}>{u.matchScore}<span style={{fontSize:11,fontWeight:400}}>점</span></span>
            </div>
            <div style={{display:'flex',gap:14,alignItems:'center'}}>
              <div style={{fontSize:36,width:54,height:54,borderRadius:27,background:'linear-gradient(135deg,rgba(160,120,200,0.15),rgba(160,120,200,0.05))',display:'flex',alignItems:'center',justifyContent:'center',border:'1px solid rgba(160,120,200,0.15)',flexShrink:0}}>{u.emoji}</div>
              <div style={{flex:1}}>
                <div style={{display:'flex',alignItems:'baseline',gap:6}}>
                  <span style={{fontSize:16,fontWeight:700,color:'#e0d0f0'}}>{u.name}</span>
                  <span style={{fontSize:11,color:'#8070a0'}}>{u.age}세 · {u.ilju}일주</span>
                </div>
                <div style={{fontSize:11,color:'#a098b8',marginTop:4,lineHeight:1.6}}>{u.bio}</div>
                <div style={{fontSize:10,color:'#6a5e8d',marginTop:4}}>{u.personality}</div>
              </div>
            </div>
            <div style={{marginTop:10,padding:'8px 12px',background:'rgba(160,120,200,0.06)',borderRadius:8,fontSize:11,color:'#b0a8d0',lineHeight:1.6}}>
              <span style={{fontWeight:600,color:'#8060c0'}}>🔮 바리만신曰:</span> {u.matchComment}
            </div>
            <div style={{textAlign:'center',marginTop:10}}>
              <span style={{fontSize:12,fontWeight:600,color:'#a090d0'}}>대화하기 →</span>
            </div>
          </div>
        );
      })}

      <button onClick={function(){setCatNavStep(6);setCatNavLoading(null);setPhase('catNav');}} style={{width:'100%',marginTop:12,background:'transparent',border:'1px solid rgba(160,120,200,0.15)',borderRadius:8,padding:'10px',fontSize:12,color:'#6050a0',cursor:'pointer'}}>돌아가기</button>
    </div>
  );

  // ============================================================
  // 인연찾기 — 1:1 채팅 화면
  // ============================================================
  if(phase==='chat'&&chatTarget)return(
    <div style={{minHeight:'100vh',background:'radial-gradient(ellipse at 50% 15%,#1a1028,#0e0a18)',color:'#e8d5a8',fontFamily:"'Noto Sans KR',sans-serif",display:'flex',flexDirection:'column',maxWidth:440,margin:'0 auto'}}>
      {/* 헤더 */}
      <div style={{display:'flex',alignItems:'center',gap:10,padding:'12px 16px',borderBottom:'1px solid rgba(160,120,200,0.1)',background:'rgba(160,120,200,0.04)'}}>
        <button onClick={function(){setPhase('matches');setChatTarget(null);}} style={{background:'transparent',border:'none',color:'#a090d0',fontSize:18,cursor:'pointer',padding:0}}>←</button>
        <div style={{fontSize:24,width:36,height:36,borderRadius:18,background:'linear-gradient(135deg,rgba(160,120,200,0.15),rgba(160,120,200,0.05))',display:'flex',alignItems:'center',justifyContent:'center',border:'1px solid rgba(160,120,200,0.1)'}}>{chatTarget.emoji}</div>
        <div style={{flex:1}}>
          <div style={{fontSize:14,fontWeight:700,color:'#e0d0f0'}}>{chatTarget.name}</div>
          <div style={{fontSize:10,color:'#6050a0'}}>{chatTarget.ilju}일주 · {chatTarget.matchGrade} {chatTarget.matchScore}점</div>
        </div>
      </div>

      {/* 메시지 영역 */}
      <div style={{flex:1,overflowY:'auto',padding:'12px 16px',display:'flex',flexDirection:'column',gap:6,minHeight:300}}>
        <div style={{textAlign:'center',padding:'12px',marginBottom:8}}>
          <div style={{fontSize:10,color:'#6050a0'}}>바리만신이 점지한 인연 · {chatTarget.matchReason}</div>
        </div>
        {(chatMsgs[chatTarget.key]||[]).map(function(msg,i){
          var isMe=msg.from==='me';
          return(
            <div key={i} style={{display:'flex',justifyContent:isMe?'flex-end':'flex-start',gap:6,alignItems:'flex-end'}}>
              {!isMe&&<div style={{fontSize:18,flexShrink:0}}>{chatTarget.emoji}</div>}
              <div style={{maxWidth:'75%',padding:'8px 12px',borderRadius:isMe?'12px 12px 0 12px':'12px 12px 12px 0',background:isMe?'linear-gradient(135deg,#5030a0,#3020a0)':'rgba(160,120,200,0.08)',border:isMe?'none':'1px solid rgba(160,120,200,0.1)'}}>
                <div style={{fontSize:13,lineHeight:1.6,color:isMe?'#fff':'#c0b8d0',whiteSpace:'pre-line'}}>{msg.text}</div>
              </div>
            </div>
          );
        })}
        {yChatLoading&&(
          <div style={{display:'flex',gap:6,alignItems:'flex-end'}}>
            <div style={{fontSize:18}}>{chatTarget.emoji}</div>
            <div style={{padding:'10px 16px',borderRadius:'12px 12px 12px 0',background:'rgba(160,120,200,0.08)',border:'1px solid rgba(160,120,200,0.1)'}}>
              <div style={{display:'flex',gap:4}}>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0s infinite'}}/>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0.2s infinite'}}/>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0.4s infinite'}}/>
              </div>
            </div>
          </div>
        )}
        <div ref={yChatEndRef}/>
      </div>

      {/* 입력 */}
      <div style={{display:'flex',gap:8,padding:'12px 16px',borderTop:'1px solid rgba(160,120,200,0.1)',background:'rgba(160,120,200,0.02)'}}>
        <input value={chatInput} onChange={function(e){setChatInput(e.target.value);}} onKeyDown={function(e){if(e.key==='Enter')doSend();}} placeholder="메시지를 입력하세요..." style={{flex:1,padding:'10px 14px',borderRadius:20,border:'1px solid rgba(160,120,200,0.2)',background:'rgba(160,120,200,0.04)',color:'#d0b0ff',fontSize:13,outline:'none'}}/>
        <button onClick={doSend} disabled={yChatLoading} style={{padding:'10px 16px',borderRadius:20,border:'none',background:chatInput.trim()&&!yChatLoading?'linear-gradient(135deg,#8060c0,#5030a0)':'rgba(160,120,200,0.1)',color:chatInput.trim()&&!yChatLoading?'#fff':'#6050a0',fontSize:13,fontWeight:700,cursor:'pointer'}}>전송</button>
      </div>
    </div>
  );

  return null;
}
