// ── 서사블록 → 사용자 친화 카테고리 분류 ──
function classifyNarrativeBlocks(blocks,result){
  var cats={
    '타고난 나':[],
    '돈과 직업':[],
    '인연과 사람':[],
    '조심할 것들':[],
    '인생의 흐름':[]
  };
  blocks.forEach(function(b){
    // 타고난 나: 일주, 일간성정, 강약, 격국, 오행, 조후, 십이운성
    if(['ilju','ilgan','gangak','gyeokguk','oheng','johu','unsung'].indexOf(b.type)>=0){
      cats['타고난 나'].push(b);
    }
    // 인연과 사람: 궁성 관련
    else if(b.type==='gungsung'||b.type==='spouse'||b.type==='family'){
      cats['인연과 사람'].push(b);
    }
    // 인생의 흐름: 전환점, 대운
    else if(b.type==='reversal'||b.type==='daeun'||b.type==='timeline'){
      cats['인생의 흐름'].push(b);
    }
    // 조심할 것들: 흉신, 경고, 공망, 충/형/해/파(부정적)
    else if(['hyungsin','warning','gongmang','hyeong','hae','pa'].indexOf(b.type)>=0){
      cats['조심할 것들'].push(b);
    }
    // 충/합: 맥락에 따라 분류
    else if(b.type==='chung'){
      cats['조심할 것들'].push(b);
    }
    else if(b.type==='hap'||b.type==='banghap'){
      cats['타고난 나'].push(b);
    }
    // 길신: 관련 주제에 분배
    else if(b.type==='gilsin'){
      // 문창/학당 → 타고난 나, 천을귀인 → 돈과 직업, 나머지 → 타고난 나
      if(b.title&&(b.title.indexOf('천을')>=0||b.title.indexOf('천덕')>=0||b.title.indexOf('월덕')>=0)){
        cats['돈과 직업'].push(b);
      }else if(b.title&&(b.title.indexOf('홍염')>=0||b.title.indexOf('도화')>=0||b.title.indexOf('반안')>=0)){
        cats['인연과 사람'].push(b);
      }else{
        cats['타고난 나'].push(b);
      }
    }
    // 특수조합: 내용에 따라
    else if(b.type==='special'||b.type==='combo'){
      if(b.title&&(b.title.indexOf('재')>=0||b.title.indexOf('식상생')>=0)){
        cats['돈과 직업'].push(b);
      }else if(b.title&&(b.title.indexOf('관살')>=0||b.title.indexOf('상관견관')>=0)){
        cats['조심할 것들'].push(b);
      }else{
        cats['타고난 나'].push(b);
      }
    }
    // 기본: 타고난 나
    else{
      cats['타고난 나'].push(b);
    }
  });
  // 돈과 직업이 비어있으면 재물 관련 서사 생성
  if(cats['돈과 직업'].length===0&&result){
    cats['돈과 직업'].push({type:'money',title:'재물운 종합',text:(result.십성.정재+result.십성.편재)>0?'재성이 사주에 있어 재물 인연이 있는 명식이네. 용신 '+result.용신+'의 기운이 올 때 재물운이 열리느니라.':'재성이 사주에 없어 대운에서 재성이 올 때를 잘 포착해야 하느니라.'});
  }
  // 인연과 사람이 비어있으면 기본 서사 생성
  if(cats['인연과 사람'].length===0&&result){
    cats['인연과 사람'].push({type:'family',title:'인연 종합',text:'일지 '+result.일지+'의 기운으로 배우자와의 관계를 살피건대, '+(result.강약==='신강'?'신강한 기운이 강해 배우자를 압도할 수 있으니 양보의 미덕이 필요하네.':'신약한 기운이라 배우자의 도움이 큰 힘이 되느니라.')});
  }
  // 인생의 흐름이 비어있으면 대운 기반 서사 생성
  if(cats['인생의 흐름'].length===0&&result&&result.대운){
    cats['인생의 흐름'].push({type:'daeun',title:'대운의 흐름',text:'대운이 10년 단위로 바뀌며 인생의 큰 물결을 만드네. 용신 '+result.용신+'이 오는 대운이 가장 좋은 시기이니, 그때를 대비하여 실력을 갈고닦아야 하느니라.'});
  }
  return cats;
}

