const ILJU_NARRATIVE={'甲子':{title:'겨울 숲의 우레',desc:'한겨울에 뿌리를 내린 거목 — 겉은 고요하지만 속에 거대한 에너지를 품고 있는 사주이네. 학문과 예술에 천부적 재능이 있고, 말년에 큰 복록이 기다리고 있네.'},'甲戌':{title:'민둥산의 고목',desc:'황야에 홀로 선 나무처럼 강인한 독립심을 가진 사주이네. 직감이 뛰어나고 리더십이 타고났네.'},'甲申':{title:'절벽 위의 소나무',desc:'절처봉생(絕處逢生) — 위기에서 빛나는 사주이네. 다재다능하고 임기응변에 뛰어나네.'},'甲午':{title:'푸른 야생마',desc:'청운의 꿈을 품은 열정적인 사주이네. 도전정신과 개척자 기질이 넘치네. 불꽃 같은 에너지를 조절할 줄 알면 큰 그릇이 될 수 있네.'},'甲辰':{title:'청룡백호의 기세',desc:'변화무쌍한 용의 기운을 타고난 사주이네. 속전속결의 결단력이 있고, 고난 뒤에 재물복이 찾아오네.'},'甲寅':{title:'깊은 산의 맹호',desc:'심산맹호(深山猛虎) — 타고난 1등의 기질을 가진 사주이네. 순수하면서도 자존심이 강하네. 동량지재(棟梁之材)의 큰 인물이 될 수 있네.'},'乙丑':{title:'인동초의 생명력',desc:'한겨울에도 꽃을 피우는 인동초 같은 사주이네. 인내심과 지구력이 남다르고, 초지일관의 끈기로 반드시 결실을 맺네.'},'乙亥':{title:'물 위의 수련',desc:'청순한 수련처럼 고고하고 아름다운 사주이네. 겉보기보다 강인하네. 무역이나 해외 인연이 강하네.'},'乙酉':{title:'정갈한 분재',desc:'정성스레 다듬어진 분재처럼 반듯하고 세련된 사주이네. 생명력이 강하고 직감이 뛰어나네.'},'乙未':{title:'초원의 갈대',desc:'바람에 흔들려도 꺾이지 않는 갈대 같은 사주이네. 자기보존 능력이 최고이네. 생활력이 강해서 어디서든 뿌리를 내리네.'},'乙巳':{title:'봄날의 촉새',desc:'화사하게 피어난 봄꽃처럼 밝고 활발한 사주이네. 화술이 뛰어나고 용모가 수려하네.'},'乙卯':{title:'봄숲의 산토끼',desc:'순수하면서도 외유내강(外柔內剛)한 사주이네. 민첩하고 근면해서 어떤 난관도 극복하는 힘이 있네.'},'丙寅':{title:'양춘의 해맞이',desc:'봄날 동쪽에서 떠오르는 태양 같은 사주이네. 목화통명(木火通明)의 총명함이 있어 학업과 교육에서 빛나네.'},'丙子':{title:'호수 위의 태양',desc:'맑은 호수에 비친 태양처럼 외양내음의 깊이가 있는 사주이네. 영감이 뛰어나고 신비로운 매력이 있네.'},'丙戌':{title:'서산의 노을',desc:'장엄한 석양 같은 사주이네. 책임감이 강하고 지독한 일벌레 기질이 있네. 용광로처럼 무엇이든 녹여내는 포용력을 가졌네.'},'丙申':{title:'불꽃놀이의 마술사',desc:'화려한 불꽃놀이처럼 다재다능하고 능수능란한 사주이네. 팔방미인에 엔터테인먼트 감각이 탁월하네.'},'丙午':{title:'한낮의 제왕',desc:'정오의 태양처럼 강렬한 빛을 발하는 사주이네. 제왕지좌에 앉아 타고난 리더십과 카리스마가 있네.'},'丙辰':{title:'불 뿜는 적룡',desc:'하늘을 나는 적룡(赤龍)처럼 화술과 입담이 뛰어난 사주이네. 스케일이 크고 당당하며 만인을 구제할 기운을 품고 있네.'},'丁卯':{title:'숲속의 별빛',desc:'어둠 속에서 빛나는 별처럼 낭만적이고 순수한 사주이네. 명석한 두뇌와 동정심을 겸비한 음유시인의 기질이 있네.'},'丁丑':{title:'섣달의 촛불',desc:'한겨울 어둠을 밝히는 촛불 같은 사주이네. 고뇌와 창작의 에너지가 넘치네. 일복과 재복을 동시에 잡을 수 있네.'},'丁亥':{title:'별빛 비친 호수',desc:'깊은 호수에 비친 별빛처럼 영민하고 명석한 사주이네. 독심술에 가까운 직관력이 있네.'},'丁酉':{title:'산사의 반딧불',desc:'고요한 산사에서 빛나는 반딧불 같은 사주이네. 카리스마와 섬세함을 동시에 가진 분위기의 달인이네.'},'丁未':{title:'화원의 별빛',desc:'밤하늘 아래 아름다운 화원처럼 풍류와 기예에 재능이 있는 사주이네. 달변가이며 멘토 기질이 있네.'},'丁巳':{title:'타오르는 별',desc:'별빛이 불꽃으로 변한 강렬한 사주이네. 리더십이 뛰어나고 솔직담백하네. 주변을 압도하는 카리스마가 있네.'},'戊辰':{title:'진흙 속의 용',desc:'고진감래(苦盡甘來)의 사주이네. 때가 오면 하늘로 비상할 거대한 잠재력을 품고 있네.'},'戊寅':{title:'민둥산의 호랑이',desc:'과시욕과 지도력을 겸비한 강인한 사주이네. 자존심이 강하고 자립심이 대단하네.'},'戊子':{title:'계곡의 산',desc:'묵직하고 총명한 사주이네. 보수적이며 모성애가 깊네. 학문에 뜻을 두면 크게 이룰 수 있네.'},'戊戌':{title:'첩첩산중의 장군',desc:'겹겹이 쌓인 산맥처럼 웅장하고 깊은 사주이네. 높은 뜻이 있으면서도 누구든 품어주는 포용력이 있네.'},'戊申':{title:'철광산의 보물',desc:'산 속에 숨겨진 금맥처럼 재물복이 타고난 사주이네. 사업가 기질이 있고 스케일이 크네.'},'戊午':{title:'활화산의 용암',desc:'뜨거운 용암처럼 폭발적인 에너지를 가진 사주이네. 미적 감각이 뛰어나 손재주가 좋네. 리더 기질과 정교함을 동시에 가졌네.'},'己巳':{title:'불을 품은 대지',desc:'화로처럼 뜨거운 열정을 품은 사주이네. 진취적이고 변신의 달인이네. 은근한 카리스마가 있네.'},'己卯':{title:'들판의 자유로운 토끼',desc:'기묘(奇妙)한 팔자를 타고난 자유로운 영혼의 사주이네. 민첩하고 자유분방하네.'},'己丑':{title:'기름진 밭의 황소',desc:'비옥한 토지에서 묵묵히 일하는 황소처럼 근면성실한 사주이네. 의식주가 풍족하고 초지일관의 집념이 대단하네.'},'己亥':{title:'안개 속의 오리',desc:'물에 잠긴 토양처럼 깊은 사색의 사주이네. 겉보기에는 한가한 듯하지만 수면 아래에서 부지런히 발을 젓고 있네.'},'己酉':{title:'산사의 종소리',desc:'맑은 종소리처럼 멘토 기질이 타고난 사주이네. 외유내강하며 절제력이 뛰어나네.'},'己未':{title:'들판의 전봇대',desc:'넓은 들판에 우뚝 서서 빛을 밝히는 사주이네. 겉은 선하지만 속은 단단하네.'},'庚午':{title:'백마 탄 기사',desc:'고고한 백마처럼 품위를 추구하는 사주이네. 미적 감각이 뛰어나고 뜨거운 내면을 화려한 겉모습으로 감싸고 있네.'},'庚辰':{title:'백룡의 눈빛',desc:'총명하고 출세욕이 강한 백룡의 사주이네. 팔방미인에 눈치가 빠르고 속전속결의 결단력이 있네.'},'庚寅':{title:'새벽의 백호',desc:'숲속을 질주하는 백호처럼 의리 있고 강직한 사주이네. 프론티어 정신이 강하고 한번 결심하면 거침이 없네.'},'庚子':{title:'바위 아래 석간수',desc:'금수쌍청 — 바위 틈을 흐르는 맑은 물처럼 깨끗하고 냉철한 사주이네. 차가운 지성 속에 따뜻함이 숨어있네.'},'庚戌':{title:'서산의 보름달',desc:'직감력과 관찰력이 뛰어난 사주이네. 유아독존의 고고한 기질에 만인을 계도할 지도력이 있네.'},'庚申':{title:'강철의 의지',desc:'쇠뭉치처럼 단단한 의지력을 가진 사주이네. 혁명적이고 목표 지향적이며 다재다능하네.'},'辛未':{title:'서리 내린 꽃밭',desc:'서리 속에서도 빛나는 꽃처럼 냉정하면서도 아름다운 사주이네. 기획력이 뛰어나고 재물복까지 갖추었네.'},'辛巳':{title:'비밀의 신사',desc:'신사 같은 품격에 탐정 같은 통찰력을 가진 사주이네. 냉철한 판단력으로 큰 일을 이루네.'},'辛卯':{title:'달빛 아래 옥토끼',desc:'깔끔하고 단정한 사주이네. 외모가 수려하고 예술적 감각이 뛰어나네.'},'辛丑':{title:'워낭의 소리',desc:'인내력이 대단한 사주이네. 우직하면서도 섬세하고, 신용을 목숨처럼 여기네.'},'辛亥':{title:'물속의 보석',desc:'물에 씻어 빛나는 주옥처럼 창의력이 넘치는 사주이네. 유레카의 순간이 자주 찾아오네.'},'辛酉':{title:'순백의 달',desc:'순백의 아름다움을 가진 사주이네. 청량하고 순수하며 호불호가 분명하네.'},'壬申':{title:'물속의 금맥',desc:'깊은 물속에 숨겨진 광맥 같은 사주이네. 여유와 융통성이 있고 해외 인연이 강하네.'},'壬午':{title:'검은 명마',desc:'오추마처럼 힘차게 달리는 사주이네. 배우자에게 충실하고 수완가 기질이 있네.'},'壬辰':{title:'잠룡의 기운',desc:'물속에 잠긴 흑룡처럼 변화무쌍하고 거대한 잠재력을 품은 사주이네.'},'壬寅':{title:'물가의 야행 호랑이',desc:'포커페이스의 달인이자 호시탐탐 기회를 노리는 사주이네. 학식이 풍부하고 자비심이 깊네.'},'壬子':{title:'망망대해의 주인',desc:'끝없는 바다처럼 포용력과 진중함을 가진 사주이네. 조직을 이끄는 CEO의 기질이 있네.'},'壬戌':{title:'사력댐의 영웅',desc:'만인에게 덕을 베푸는 영웅호걸의 사주이네. 통이 크고 위기에서 더 빛나네. 숨겨진 재복이 대단하네.'},'癸酉':{title:'봄비 내리는 산사',desc:'고요한 산사에 내리는 봄비처럼 맑고 결백한 사주이네. 종교적 감성과 예술적 기질을 타고났네.'},'癸未':{title:'개미집의 여왕',desc:'겉은 소박하지만 풍족한 식록을 품고 있는 사주이네. 밖에서는 능력자이면서 단단한 생활력이 있네.'},'癸巳':{title:'한낮의 실개천',desc:'햇살 아래 반짝이는 실개천처럼 여유롭고 지혜로운 사주이네. 의식주가 넉넉하고 인정이 많네.'},'癸卯':{title:'옹달샘의 토끼',desc:'초목과 봄비가 어우러진 평화로운 사주이네. 만사순성의 기운이 있고 식복이 좋네.'},'癸丑':{title:'엄동설한의 불꽃',desc:'한겨울 눈보라 속에서 피어나는 불꽃 같은 사주이네. 절처봉생의 반전 기운이 있네.'},'癸亥':{title:'지혜의 바다',desc:'유유자적하는 지혜의 신 같은 사주이네. 속전속결의 결단력과 대인관계의 달인이네.'}};
const GANGYA_NARR={'신강':{p:'타고난 체력과 추진력이 강해서, 스스로 길을 개척하는 자수성가형이네.',c:'너무 강한 기운은 때로 고집으로 나타날 수 있으니 주변의 조언에 귀를 기울여보게.'},'신약':{p:'예민하고 섬세한 감각이 있어서, 시대의 흐름을 빠르게 읽는 촉이 있네.',c:'에너지가 분산되기 쉬운 구조라 용신 환경을 잘 활용하는 게 성공의 열쇠이네.'}};
const GYEOKGUK_NARR={'식신격':'타고난 표현력과 창작 능력이 있네. 먹는 것에 복이 있고 교육 분야에서 두각을 나타낼 수 있네.','상관격':'틀을 깨는 창의력과 반항적 에너지가 있네. 혁신가 기질이 강하네.','정재격':'안정적으로 재물을 모으는 축재의 기운이 있네. 꾸준히 부를 쌓아가는 타입이네.','편재격':'큰돈을 다루는 그릇이네. 투자나 사업에 감이 있네.','정관격':'질서와 원칙을 중시하는 사주이네. 승진운과 사회적 인정이 따르네.','편관격':'강렬한 카리스마와 통솔력이 있네. 리더십이 요구되는 분야에 적합하네.','정인격':'학문과 자격증에 강한 사주이네. 귀인이 따르고 배움으로 인생을 열어가는 타입이네.','편인격':'독특한 사고방식과 비범한 재능이 있네. 의술, 종교, 철학 등에서 빛을 발하네.','비견격':'독립심이 강하고 경쟁에서 이기는 힘이 있네. 자기 사업으로 성공할 수 있네.','겁재격':'승부욕이 강하고 대담하네. 도전정신으로 큰 판을 벌일 수 있네.'};
const CHUNG_NARR={'자오충':'삶에 극적인 전환점이 오는 사주이네. 큰 변화 속에서 성장하는 힘이 있네.','축미충':'가치관의 충돌을 경험하지만, 이를 통해 자신만의 철학을 세울 수 있네.','인신충':'끊임없는 이동과 변화 속에서 기회를 잡는 사주이네.','묘유충':'감성과 이성의 갈등이 있지만, 이를 조화시키면 놀라운 창작 능력이 발휘되네.','진술충':'큰 변화의 기운이네. 고집이 세지만 그만큼 큰일을 벌일 수 있네.','사해충':'지혜와 행동 사이의 긴장감이 있네. 위기에서 기회를 만들어내.'};
const HAP_NARR={'자축합':'안정과 결속의 기운이 강하네. 신뢰할 수 있는 파트너를 만나면 시너지가 폭발하네.','인해합':'봉사와 출세를 동시에 추구하는 기운이네.','묘술합':'재적 성취를 향한 강한 추진력이 있네.','진유합':'문학과 예술적 감각이 뛰어나네.','사신합':'지혜와 활동력의 조합이네. 수완이 좋고 대인관계에서 유리하네.','오미합':'태양과 대지의 만남처럼 풍요롭고 따뜻한 기운이네. 가정에 복이 있네.'};
function generateNarrative(r){var b=[];var ilju=r.일간+r.일지;var ij=ILJU_NARRATIVE[ilju];if(ij)b.push({type:'ilju',title:'✦ '+ilju+'일주 — '+ij.title,text:ij.desc});var gn=GANGYA_NARR[r.강약];if(gn)b.push({type:'gangya',text:gn.p+' '+gn.c});if(r.격국&&GYEOKGUK_NARR[r.격국])b.push({type:'gyeokguk',title:r.격국,text:GYEOKGUK_NARR[r.격국]});var ss=r.십성;if(r.강약==='신약'&&(ss.정재+ss.편재)>=3)b.push({type:'special',text:'재물이 많이 보이지만 잡기 어려운 형국이네. 용신 대운이 오면 한번에 크게 잡을 수 있네.'});if(ss.정관>=1&&ss.편관>=1)b.push({type:'special',text:'관살혼잡의 구조이네. 여러 갈래의 압박이 있지만, 극복하면 큰 성취가 가능하네.'});if((ss.식신+ss.상관)>=1&&(ss.정재+ss.편재)>=1)b.push({type:'special',text:'식상생재의 흐름이 있네. 재능으로 돈을 버는 구조이네.'});if(ss.편관>=1&&(ss.정인+ss.편인)>=1)b.push({type:'special',text:'살인상생의 좋은 구조이네. 외부의 압력을 학문과 지혜로 승화시키는 힘이 있네.'});if((ss.정재+ss.편재)>=1&&(ss.정관+ss.편관)>=1&&r.강약==='신강')b.push({type:'special',text:'재관이 함께 있고 일간이 강해서 재물과 명예를 동시에 쥘 수 있는 팔자이네.'});if(r.충)r.충.forEach(function(c){var j1=c.지1,j2=c.지2;var jmap={'子':'자','丑':'축','寅':'인','卯':'묘','辰':'진','巳':'사','午':'오','未':'미','申':'신','酉':'유','戌':'술','亥':'해'};var k=(jmap[j1]||'')+(jmap[j2]||'')+'충';if(CHUNG_NARR[k])b.push({type:'chung',text:CHUNG_NARR[k]});});if(r.합)r.합.forEach(function(h){var hs=typeof h==='string'?h:'';Object.keys(HAP_NARR).forEach(function(k){var hj={'자':'子','축':'丑','인':'寅','묘':'卯','진':'辰','사':'巳','오':'午','미':'未','신':'申','유':'酉','술':'戌','해':'亥'};var c1=hj[k[0]],c2=hj[k[1]];if(c1&&c2&&hs.includes(c1)&&hs.includes(c2))b.push({type:'hap',text:HAP_NARR[k]});});});if(r.대운&&r.대운.length>0){var yoh=r.용신;var goh={'甲':'목','乙':'목','丙':'화','丁':'화','戊':'토','己':'토','庚':'금','辛':'금','壬':'수','癸':'수'};for(var i=0;i<r.대운.length;i++){var dw=r.대운[i];var tc=dw.간지?dw.간지[0]:'';if(tc&&goh[tc]===yoh){var age=(i+1)*10;b.push({type:'reversal',text:age+'대 무렵('+dw.간지+' 대운)에 용신 '+yoh+'의 기운이 들어와 큰 전환점이 될 수 있네. 이 시기를 잘 준비하면 인생이 크게 달라질 것이네.'});break;}}}return b;}

function analyze(s){
  const G=[s.yg,s.mg,s.dg,s.hg], Z=[s.yj,s.mj,s.dj,s.hj];
  const 일간=s.dg, 일지=s.dj, gender=s.gender;
  
  // 오행 분포 — 지장간 일수(日數) 기반 + 완만한 왕상 보정
  // 辰戌丑未 = 토 계절 (토왕용사)
  var 월지계절2={'寅':'봄','卯':'봄','巳':'여름','午':'여름','申':'가을','酉':'가을','亥':'겨울','子':'겨울','辰':'토','未':'토','戌':'토','丑':'토'};
  var 왕상2={
    '봄':{목:1.2,화:1.1,수:1.0,금:0.85,토:0.85},
    '여름':{화:1.2,토:1.1,목:1.0,수:0.85,금:0.85},
    '가을':{금:1.2,수:1.1,토:1.0,목:0.85,화:0.85},
    '겨울':{수:1.2,목:1.1,금:1.0,토:0.85,화:0.85},
    '토':{토:1.2,금:1.2,수:1.0,화:0.85,목:0.85}
  };
  var 계절2=월지계절2[s.mj]||'봄';
  var ws=왕상2[계절2];
  var 지장간비율={
    '子':[0.33,0.67],         // 壬10일, 癸20일
    '丑':[0.30,0.10,0.60],   // 癸9, 辛3, 己18
    '寅':[0.23,0.23,0.54],   // 戊7, 丙7, 甲16
    '卯':[0.33,0.67],         // 甲10, 乙20
    '辰':[0.30,0.10,0.60],   // 乙9, 癸3, 戊18
    '巳':[0.17,0.30,0.53],   // 戊5, 庚9, 丙16
    '午':[0.33,0.30,0.37],   // 丙10, 己9, 丁11
    '未':[0.30,0.10,0.60],   // 丁9, 乙3, 己18
    '申':[0.33,0.10,0.57],   // 己10, 壬3, 庚17
    '酉':[0.33,0.67],         // 庚10, 辛20
    '戌':[0.30,0.10,0.60],   // 辛9, 丁3, 戊18
    '亥':[0.23,0.17,0.60]    // 戊7, 甲5, 壬18
  };
  const 오행카운트={목:0,화:0,토:0,금:0,수:0};
  // 천간: 각 1.0 × 왕상
  G.forEach(function(g){var oh=천간오행[g];if(oh)오행카운트[oh]+=1*(ws[oh]||1);});
  // 지지: 일수 비율 × 왕상
  Z.forEach(function(z){
    var jj=지장간T[z];
    if(!jj)return;
    var weights=지장간비율[z]||[0.33,0.67];
    jj.forEach(function(ch,idx){
      var oh=천간오행[ch];
      if(oh&&weights[idx])오행카운트[oh]+=weights[idx]*(ws[oh]||1);
    });
  });
  // 소수점 정리
  Object.keys(오행카운트).forEach(function(k){오행카운트[k]=Math.round(오행카운트[k]*100)/100;});
  const total=Object.values(오행카운트).reduce(function(a,b){return a+b;},0);
  // 전무/과다 판정
  const 전무=Object.keys(오행카운트).filter(function(k){return 오행카운트[k]<0.1;});
  const 과다=Object.keys(오행카운트).filter(function(k){return total>0&&(오행카운트[k]/total)>=0.35;});
  // 백분율 계산
  const 오행퍼센트={};
  Object.keys(오행카운트).forEach(function(k){오행퍼센트[k]=total>0?Math.round(오행카운트[k]/total*100):0;});
  
  // 십성 계산 (일간 자신은 제외)
  const 십성카운트={비견:0,겁재:0,식신:0,상관:0,편재:0,정재:0,편관:0,정관:0,편인:0,정인:0};
  var 십성대상=[s.yg,s.mg,s.hg]; // 천간 3개 (일간 제외)
  Z.forEach(function(z){var jk=정기T[z];if(jk)십성대상.push(jk);}); // 지지 정기 4개
  십성대상.forEach(function(ch){
    if(!ch||ch==='?')return;
    var target=천간오행[ch]?ch:정기T[ch];
    if(target){var ss=십성(일간,target);if(ss)십성카운트[ss]++;}
  });
  
  // ===== Phase 2: 새 강약/용신 판정 =====
  const 강약결과=강약판정(일간, s.mj, G, Z);
  const 강약=강약결과.강약;
  const 강약등급=강약결과.등급;
  
  const 용신결과=용신판정(일간, s.mj, 강약결과);
  const 용신오행=용신결과.용신;
  
  // 격국 (기존 유지)
  const 월지정기=정기T[s.mj];
  const 격국십성=십성(일간,월지정기);
  const 격국이름=격국십성+'격';
  
  // ===== 충 감지 (기존 유지) =====
  const 충쌍=[['子','午'],['丑','未'],['寅','申'],['卯','酉'],['辰','戌'],['巳','亥']];
  const 충목록=[];
  const 위치=['연','월','일','시'];
  for(let i=0;i<4;i++)for(let j=i+1;j<4;j++){
    for(const[a,b]of 충쌍){
      if((Z[i]===a&&Z[j]===b)||(Z[i]===b&&Z[j]===a)){
        충목록.push({위치:`${위치[i]}${위치[j]}`,지1:Z[i],지2:Z[j]});
      }
    }
  }
  
  // 형살 감지 (기존 유지)
  const 형쌍=[['寅','巳','申','인사신 삼형'],['丑','戌','未','축술미 삼형'],['子','卯','','자묘형'],['辰','辰','','진진 자형'],['午','午','','오오 자형'],['酉','酉','','유유 자형'],['亥','亥','','해해 자형']];
  const 형목록=[];
  for(const[a,b,c,name]of 형쌍){
    const has=z=>Z.includes(z);
    if(c){if(has(a)&&has(b)&&has(c))형목록.push(name);}
    else if(a===b){const cnt=Z.filter(z=>z===a).length;if(cnt>=2)형목록.push(name);}
    else{if(has(a)&&has(b))형목록.push(name);}
  }
  
  // 합 감지 (기존 유지)
  const 육합쌍=[['子','丑','토'],['寅','亥','목'],['卯','戌','화'],['辰','酉','금'],['巳','申','수'],['午','未','화']];
  const 합목록=[];
  for(const[a,b,o]of 육합쌍){
    if(Z.includes(a)&&Z.includes(b))합목록.push(`${a}${b}합(${o})`);
  }
  const 삼합쌍=[['申','子','辰','수'],['寅','午','戌','화'],['巳','酉','丑','금'],['亥','卯','未','목']];
  for(const[a,b,c,o]of 삼합쌍){
    if(Z.includes(a)&&Z.includes(b)&&Z.includes(c))합목록.push(`${a}${b}${c}삼합(${o})`);
  }

  // ===== Phase 2: 새 관계 분석 =====
  const 천간합목록=천간합감지(G);
  const 천간충목록=천간충감지(G);
  const 해목록=해감지(Z);
  const 파목록=파감지(Z);
  const 방합목록=방합감지(Z);
  const 반합목록=반합감지(Z);
  
  // ===== Phase 3: 신살 =====
  const 신살=신살판정(일간, 일지, Z[0], Z[1], Z[3], G, Z);
  
  // ===== 십이운성 =====
  const 운성=사주운성(일간, Z);
  
  // ===== 공망 =====
  const 공망결과=공망체크(일간, 일지, Z);

  // ===== 점수 산출 (개선) =====
  const 오행장기={목:{장:'간',부:'담'},화:{장:'심장',부:'소장'},토:{장:'비장',부:'위'},금:{장:'폐',부:'대장'},수:{장:'신장',부:'방광'}};
  const 건강경고=[];
  전무.forEach(oh=>{const organ=오행장기[oh];if(organ)건강경고.push(`${organ.장}[${oh}] 허약하니 주의해`);});
  과다.forEach(oh=>{const organ=오행장기[oh];if(organ)건강경고.push(`${organ.부}[${oh}] 과다 — 열/염증 조심해`);});
  충목록.forEach(c=>{if(c.위치==='일시')건강경고.push('일시충 — 말년에 건강 변동이 올 수 있어');});
  // 신살 기반 건강 경고
  신살.흉신.forEach(s=>{if(s.명.includes('백호'))건강경고.push('백호살 — 혈광/사고 주의');});

  function relScore(십성1, 십성2) {
    const cnt1=십성카운트[십성1]||0, cnt2=십성카운트[십성2]||0;
    const base=35;
    const bonus=(cnt1+cnt2)*15;
    const 충패널티=충목록.length*7;
    const 신살보너스=신살.길신.length*3;
    return Math.min(95, Math.max(10, base+bonus-충패널티+신살보너스+Math.floor(Math.random()*8)));
  }
  
  function 인연(십성1,십성2){
    const cnt=십성카운트[십성1]+십성카운트[십성2];
    if(cnt>=2)return{등급:'깊은 인연',점수:75+Math.floor(Math.random()*15)};
