// 서예 만세력 — 붓글씨 애니메이션
function CalligraphyManseryeok({saju,일간,name,격국,강약,skipAnim}){
  const containerRef=useRef(null);
  const[revealed,setRevealed]=useState(skipAnim||false);
  const ilju=일간+(saju.dj||'');
  const iljuNarr=ILJU_NARRATIVE[ilju];
  // 화면 좌→우: 시|일|월|연, 애니메이션: 연→월→일→시(전통 서사순)
  const cols=[
    {key:'h',label:'시주',sub:'時柱',g:saju.hg,j:saju.hj,ord:3},
    {key:'d',label:'일주',sub:'日柱',g:saju.dg,j:saju.dj,ord:2,isDay:true},
    {key:'m',label:'월주',sub:'月柱',g:saju.mg,j:saju.mj,ord:1},
    {key:'y',label:'연주',sub:'年柱',g:saju.yg,j:saju.yj,ord:0}
  ];
  const animSeq=[];
  [...cols].sort((a,b)=>a.ord-b.ord).forEach(c=>{
    if(c.g&&c.g!=='?')animSeq.push({id:c.key+'g',ch:c.g});
    if(c.j&&c.j!=='?')animSeq.push({id:c.key+'j',ch:c.j});
  });
  useEffect(()=>{
    if(!containerRef.current)return;
    let alive=true;
    const writers=[];
    animSeq.forEach(item=>{
      const el=containerRef.current.querySelector('[data-hw="'+item.id+'"]');
      if(!el)return;
      el.innerHTML='';
      const oh=천간오행[item.ch]||지지오행[item.ch]||'';
      const c=OH_COLOR_MAP[oh];
      try{
        writers.push(HanziWriter.create(el,item.ch,{
          width:58,height:58,padding:2,
          strokeColor:c?c.fg:'#c8a85a',
          radicalColor:c?c.fg:'#b48c50',
          strokeAnimationSpeed:skipAnim?0:2,
          delayBetweenStrokes:skipAnim?0:50,
          showOutline:false,
          showCharacter:skipAnim?true:false
        }));
      }catch(e){console.warn('HanziWriter error:',item.ch,e);}
    });
    if(skipAnim){setRevealed(true);return;}
    function run(i){
      if(!alive||i>=writers.length){if(alive)setRevealed(true);return;}
      writers[i].animateCharacter({onComplete:()=>run(i+1)});
    }
    setTimeout(()=>run(0),500);
    return()=>{alive=false;};
  },[]);
