// ── 신살 뱃지 (위치별 그룹, 직관적) ──
function SinsalBadges({신살}){
  if(!신살)return null;
  var all=[].concat(
    (신살.길신||[]).map(function(s){return Object.assign({},s,{type:'길'});}),
    (신살.흉신||[]).map(function(s){return Object.assign({},s,{type:'흉'});}),
    (신살.중립||[]).map(function(s){return Object.assign({},s,{type:'중'});})
  );
  if(!all.length)return null;
  var cm={길:{bg:'rgba(80,160,80,0.08)',border:'rgba(80,160,80,0.2)',text:'#7abf6a',icon:'✦'},흉:{bg:'rgba(200,80,80,0.06)',border:'rgba(200,80,80,0.15)',text:'#d4856a',icon:'✧'},중:{bg:'rgba(160,140,100,0.06)',border:'rgba(160,140,100,0.15)',text:'#a09870',icon:'○'}};
  // 위치별 그룹
  var 위치순=['일지','월지','연지','시지'];
  var 위치명={'일지':'일지(나·배우자)','월지':'월지(부모·청년)','연지':'연지(조상·유년)','시지':'시지(자녀·노년)'};
  var grouped={};
  all.forEach(function(s){
    var pos=s.위치||'기타';
    if(!grouped[pos])grouped[pos]=[];
    grouped[pos].push(s);
  });
  var positions=위치순.filter(function(p){return grouped[p]&&grouped[p].length>0;});
  // 기타 위치 추가
  Object.keys(grouped).forEach(function(p){if(positions.indexOf(p)<0)positions.push(p);});
  
  return React.createElement('div',{style:{marginBottom:14}},
    React.createElement('div',{style:{fontSize:11,fontWeight:700,color:'#8a7e6d',marginBottom:10,letterSpacing:1}},'신살(神殺)'),
    positions.map(function(pos){
      return React.createElement('div',{key:pos,style:{marginBottom:8}},
        React.createElement('div',{style:{fontSize:9,color:'#5a5040',marginBottom:4,fontWeight:600}},위치명[pos]||pos),
        React.createElement('div',{style:{display:'flex',flexWrap:'wrap',gap:5}},
          grouped[pos].map(function(s,i){
            var c=cm[s.type]||cm['중'];
            return React.createElement('div',{key:i,style:{background:c.bg,border:'1px solid '+c.border,borderRadius:8,padding:'6px 10px',fontSize:11.5,color:c.text,fontWeight:600,display:'flex',alignItems:'center',gap:4}},
              React.createElement('span',{style:{fontSize:10}},c.icon),
              (s.명||s.이름||'')
            );
          })
        )
      );
    })
  );
}

