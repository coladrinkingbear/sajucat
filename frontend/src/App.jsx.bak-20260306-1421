      {/* Step 2: 로그인할거냥? */}
      {loginStep>=2&&loginStep<3&&(
        <div style={{animation:'fadeUp 0.5s ease',marginTop:20,textAlign:'center',width:'100%',maxWidth:320}}>
          <div style={{background:'rgba(180,140,80,0.06)',border:'1px solid rgba(180,140,80,0.12)',borderRadius:14,padding:'14px 20px',position:'relative',marginBottom:20}}>
            <div style={{position:'absolute',top:-7,left:'50%',marginLeft:-7,width:0,height:0,borderLeft:'7px solid transparent',borderRight:'7px solid transparent',borderBottom:'7px solid rgba(180,140,80,0.12)'}}/>
            <p style={{fontSize:14,color:'#c0b8a0',lineHeight:1.9,margin:0}}>어서 오라냥! 🐾<br/>로그인하면 좋은 게 많다냥~</p>
            <div style={{marginTop:10,fontSize:12,color:'#8a7e6d',lineHeight:1.8,textAlign:'left'}}>
              <div>✨ 예전 사주팔자 기록을 저장</div>
              <div>🔮 바리만신과의 채팅 내역 보관</div>
              <div>📅 매일 오늘의 운세 확인</div>
            </div>
          </div>
          <div style={{display:'flex',gap:10}}>
            <button onClick={function(){setLoginStep(3);}} style={{flex:1,padding:'12px',background:'linear-gradient(135deg,#b48c50,#8a6830)',border:'none',borderRadius:12,fontSize:14,fontWeight:700,color:'#14110c',cursor:'pointer',boxShadow:'0 4px 16px rgba(180,140,80,0.3)'}}>좋아, 할래!</button>
            <button onClick={function(){setDialogStep(0);setDialogMsgs([{who:'cat',text:'알겠다냥. 그럼 바로 사주를 봐줄게!\n먼저, 성별을 알려줘!'}]);setDialogReady(false);setPhase('dialog');}} style={{flex:1,padding:'12px',background:'transparent',border:'1px solid rgba(180,140,80,0.2)',borderRadius:12,fontSize:13,fontWeight:600,color:'#c0b8a0',cursor:'pointer'}}>아니, 그냥 볼래</button>
          </div>
