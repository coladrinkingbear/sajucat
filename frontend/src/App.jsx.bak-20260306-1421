const ILJU_NARRATIVE={'甲子':{title:'겨울 숲의 우레',desc:'한겨울에 뿌리를 내린 거목 — 겉은 고요하지만 속에 거대한 에너지를 품고 있는 사주야. 학문과 예술에 천부적 재능이 있고, 말년에 큰 복록이 기다리고 있어.'},'甲戌':{title:'민둥산의 고목',desc:'황야에 홀로 선 나무처럼 강인한 독립심을 가진 사주야. 직감이 뛰어나고 리더십이 타고났어.'},'甲申':{title:'절벽 위의 소나무',desc:'절처봉생(絕處逢生) — 위기에서 빛나는 사주야. 다재다능하고 임기응변에 뛰어나.'},'甲午':{title:'푸른 야생마',desc:'청운의 꿈을 품은 열정적인 사주야. 도전정신과 개척자 기질이 넘쳐. 불꽃 같은 에너지를 조절할 줄 알면 큰 그릇이 될 수 있어.'},'甲辰':{title:'청룡백호의 기세',desc:'변화무쌍한 용의 기운을 타고난 사주야. 속전속결의 결단력이 있고, 고난 뒤에 재물복이 찾아와.'},'甲寅':{title:'깊은 산의 맹호',desc:'심산맹호(深山猛虎) — 타고난 1등의 기질을 가진 사주야. 순수하면서도 자존심이 강해. 동량지재(棟梁之材)의 큰 인물이 될 수 있어.'},'乙丑':{title:'인동초의 생명력',desc:'한겨울에도 꽃을 피우는 인동초 같은 사주야. 인내심과 지구력이 남다르고, 초지일관의 끈기로 반드시 결실을 맺어.'},'乙亥':{title:'물 위의 수련',desc:'청순한 수련처럼 고고하고 아름다운 사주야. 겉보기보다 강인해. 무역이나 해외 인연이 강해.'},'乙酉':{title:'정갈한 분재',desc:'정성스레 다듬어진 분재처럼 반듯하고 세련된 사주야. 생명력이 강하고 직감이 뛰어나.'},'乙未':{title:'초원의 갈대',desc:'바람에 흔들려도 꺾이지 않는 갈대 같은 사주야. 자기보존 능력이 최고야. 생활력이 강해서 어디서든 뿌리를 내려.'},'乙巳':{title:'봄날의 촉새',desc:'화사하게 피어난 봄꽃처럼 밝고 활발한 사주야. 화술이 뛰어나고 용모가 수려해.'},'乙卯':{title:'봄숲의 산토끼',desc:'순수하면서도 외유내강(外柔內剛)한 사주야. 민첩하고 근면해서 어떤 난관도 극복하는 힘이 있어.'},'丙寅':{title:'양춘의 해맞이',desc:'봄날 동쪽에서 떠오르는 태양 같은 사주야. 목화통명(木火通明)의 총명함이 있어 학업과 교육에서 빛나.'},'丙子':{title:'호수 위의 태양',desc:'맑은 호수에 비친 태양처럼 외양내음의 깊이가 있는 사주야. 영감이 뛰어나고 신비로운 매력이 있어.'},'丙戌':{title:'서산의 노을',desc:'장엄한 석양 같은 사주야. 책임감이 강하고 지독한 일벌레 기질이 있어. 용광로처럼 무엇이든 녹여내는 포용력을 가졌어.'},'丙申':{title:'불꽃놀이의 마술사',desc:'화려한 불꽃놀이처럼 다재다능하고 능수능란한 사주야. 팔방미인에 엔터테인먼트 감각이 탁월해.'},'丙午':{title:'한낮의 제왕',desc:'정오의 태양처럼 강렬한 빛을 발하는 사주야. 제왕지좌에 앉아 타고난 리더십과 카리스마가 있어.'},'丙辰':{title:'불 뿜는 적룡',desc:'하늘을 나는 적룡(赤龍)처럼 화술과 입담이 뛰어난 사주야. 스케일이 크고 당당하며 만인을 구제할 기운을 품고 있어.'},'丁卯':{title:'숲속의 별빛',desc:'어둠 속에서 빛나는 별처럼 낭만적이고 순수한 사주야. 명석한 두뇌와 동정심을 겸비한 음유시인의 기질이 있어.'},'丁丑':{title:'섣달의 촛불',desc:'한겨울 어둠을 밝히는 촛불 같은 사주야. 고뇌와 창작의 에너지가 넘쳐. 일복과 재복을 동시에 잡을 수 있어.'},'丁亥':{title:'별빛 비친 호수',desc:'깊은 호수에 비친 별빛처럼 영민하고 명석한 사주야. 독심술에 가까운 직관력이 있어.'},'丁酉':{title:'산사의 반딧불',desc:'고요한 산사에서 빛나는 반딧불 같은 사주야. 카리스마와 섬세함을 동시에 가진 분위기의 달인이야.'},'丁未':{title:'화원의 별빛',desc:'밤하늘 아래 아름다운 화원처럼 풍류와 기예에 재능이 있는 사주야. 달변가이며 멘토 기질이 있어.'},'丁巳':{title:'타오르는 별',desc:'별빛이 불꽃으로 변한 강렬한 사주야. 리더십이 뛰어나고 솔직담백해. 주변을 압도하는 카리스마가 있어.'},'戊辰':{title:'진흙 속의 용',desc:'고진감래(苦盡甘來)의 사주야. 때가 오면 하늘로 비상할 거대한 잠재력을 품고 있어.'},'戊寅':{title:'민둥산의 호랑이',desc:'과시욕과 지도력을 겸비한 강인한 사주야. 자존심이 강하고 자립심이 대단해.'},'戊子':{title:'계곡의 산',desc:'묵직하고 총명한 사주야. 보수적이며 모성애가 깊어. 학문에 뜻을 두면 크게 이룰 수 있어.'},'戊戌':{title:'첩첩산중의 장군',desc:'겹겹이 쌓인 산맥처럼 웅장하고 깊은 사주야. 높은 뜻이 있으면서도 누구든 품어주는 포용력이 있어.'},'戊申':{title:'철광산의 보물',desc:'산 속에 숨겨진 금맥처럼 재물복이 타고난 사주야. 사업가 기질이 있고 스케일이 커.'},'戊午':{title:'활화산의 용암',desc:'뜨거운 용암처럼 폭발적인 에너지를 가진 사주야. 미적 감각이 뛰어나 손재주가 좋아. 리더 기질과 정교함을 동시에 가졌어.'},'己巳':{title:'불을 품은 대지',desc:'화로처럼 뜨거운 열정을 품은 사주야. 진취적이고 변신의 달인이야. 은근한 카리스마가 있어.'},'己卯':{title:'들판의 자유로운 토끼',desc:'기묘(奇妙)한 팔자를 타고난 자유로운 영혼의 사주야. 민첩하고 자유분방해.'},'己丑':{title:'기름진 밭의 황소',desc:'비옥한 토지에서 묵묵히 일하는 황소처럼 근면성실한 사주야. 의식주가 풍족하고 초지일관의 집념이 대단해.'},'己亥':{title:'안개 속의 오리',desc:'물에 잠긴 토양처럼 깊은 사색의 사주야. 겉보기에는 한가한 듯하지만 수면 아래에서 부지런히 발을 젓고 있어.'},'己酉':{title:'산사의 종소리',desc:'맑은 종소리처럼 멘토 기질이 타고난 사주야. 외유내강하며 절제력이 뛰어나.'},'己未':{title:'들판의 전봇대',desc:'넓은 들판에 우뚝 서서 빛을 밝히는 사주야. 겉은 선하지만 속은 단단해.'},'庚午':{title:'백마 탄 기사',desc:'고고한 백마처럼 품위를 추구하는 사주야. 미적 감각이 뛰어나고 뜨거운 내면을 화려한 겉모습으로 감싸고 있어.'},'庚辰':{title:'백룡의 눈빛',desc:'총명하고 출세욕이 강한 백룡의 사주야. 팔방미인에 눈치가 빠르고 속전속결의 결단력이 있어.'},'庚寅':{title:'새벽의 백호',desc:'숲속을 질주하는 백호처럼 의리 있고 강직한 사주야. 프론티어 정신이 강하고 한번 결심하면 거침이 없어.'},'庚子':{title:'바위 아래 석간수',desc:'금수쌍청 — 바위 틈을 흐르는 맑은 물처럼 깨끗하고 냉철한 사주야. 차가운 지성 속에 따뜻함이 숨어있어.'},'庚戌':{title:'서산의 보름달',desc:'직감력과 관찰력이 뛰어난 사주야. 유아독존의 고고한 기질에 만인을 계도할 지도력이 있어.'},'庚申':{title:'강철의 의지',desc:'쇠뭉치처럼 단단한 의지력을 가진 사주야. 혁명적이고 목표 지향적이며 다재다능해.'},'辛未':{title:'서리 내린 꽃밭',desc:'서리 속에서도 빛나는 꽃처럼 냉정하면서도 아름다운 사주야. 기획력이 뛰어나고 재물복까지 갖추었어.'},'辛巳':{title:'비밀의 신사',desc:'신사 같은 품격에 탐정 같은 통찰력을 가진 사주야. 냉철한 판단력으로 큰 일을 이뤄.'},'辛卯':{title:'달빛 아래 옥토끼',desc:'깔끔하고 단정한 사주야. 외모가 수려하고 예술적 감각이 뛰어나.'},'辛丑':{title:'워낭의 소리',desc:'인내력이 대단한 사주야. 우직하면서도 섬세하고, 신용을 목숨처럼 여겨.'},'辛亥':{title:'물속의 보석',desc:'물에 씻어 빛나는 주옥처럼 창의력이 넘치는 사주야. 유레카의 순간이 자주 찾아와.'},'辛酉':{title:'순백의 달',desc:'순백의 아름다움을 가진 사주야. 청량하고 순수하며 호불호가 분명해.'},'壬申':{title:'물속의 금맥',desc:'깊은 물속에 숨겨진 광맥 같은 사주야. 여유와 융통성이 있고 해외 인연이 강해.'},'壬午':{title:'검은 명마',desc:'오추마처럼 힘차게 달리는 사주야. 배우자에게 충실하고 수완가 기질이 있어.'},'壬辰':{title:'잠룡의 기운',desc:'물속에 잠긴 흑룡처럼 변화무쌍하고 거대한 잠재력을 품은 사주야.'},'壬寅':{title:'물가의 야행 호랑이',desc:'포커페이스의 달인이자 호시탐탐 기회를 노리는 사주야. 학식이 풍부하고 자비심이 깊어.'},'壬子':{title:'망망대해의 주인',desc:'끝없는 바다처럼 포용력과 진중함을 가진 사주야. 조직을 이끄는 CEO의 기질이 있어.'},'壬戌':{title:'사력댐의 영웅',desc:'만인에게 덕을 베푸는 영웅호걸의 사주야. 통이 크고 위기에서 더 빛나. 숨겨진 재복이 대단해.'},'癸酉':{title:'봄비 내리는 산사',desc:'고요한 산사에 내리는 봄비처럼 맑고 결백한 사주야. 종교적 감성과 예술적 기질을 타고났어.'},'癸未':{title:'개미집의 여왕',desc:'겉은 소박하지만 풍족한 식록을 품고 있는 사주야. 밖에서는 능력자이면서 단단한 생활력이 있어.'},'癸巳':{title:'한낮의 실개천',desc:'햇살 아래 반짝이는 실개천처럼 여유롭고 지혜로운 사주야. 의식주가 넉넉하고 인정이 많아.'},'癸卯':{title:'옹달샘의 토끼',desc:'초목과 봄비가 어우러진 평화로운 사주야. 만사순성의 기운이 있고 식복이 좋아.'},'癸丑':{title:'엄동설한의 불꽃',desc:'한겨울 눈보라 속에서 피어나는 불꽃 같은 사주야. 절처봉생의 반전 기운이 있어.'},'癸亥':{title:'지혜의 바다',desc:'유유자적하는 지혜의 신 같은 사주야. 속전속결의 결단력과 대인관계의 달인이야.'}};
