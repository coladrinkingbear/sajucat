    <div style={{minHeight:'100vh',background:'radial-gradient(ellipse at 50% 15%,#221c14 0%,#14110c 65%)',display:'flex',flexDirection:'column',alignItems:'center',color:'#e8d5a8',fontFamily:"'Noto Sans KR',sans-serif",padding:20,paddingTop:60,position:'relative',overflowY:'auto'}}>
      {/* 배경 파티클 */}
