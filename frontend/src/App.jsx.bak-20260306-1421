        <div style={{animation:'fadeUp 0.6s ease',marginTop:24,width:'100%',maxWidth:320,display:'flex',flexDirection:'column',gap:10}}>
          <button onClick={function(){setCatNavLoading('mansin');setTimeout(function(){setCatNavLoading(null);startMansinChat();},1400);}} style={{width:'100%',padding:'13px 18px',background:'linear-gradient(135deg,#b48c50,#8a6830)',border:'none',borderRadius:22,fontSize:14,fontWeight:700,color:'#fff',cursor:'pointer',boxShadow:'0 4px 16px rgba(180,140,80,0.3)',textAlign:'center'}}>🔮 바리만신과 대화하기</button>
          <button onClick={function(){setCatNavLoading('yeonin');setTimeout(function(){setCatNavLoading(null);trackAct('yeonin_start');var ym=getYeoninMatches(result.일간,form.gender);setYeoninMatches(ym);setPhase('matches');},1400);}} style={{width:'100%',padding:'13px 18px',background:'linear-gradient(135deg,#b48c50,#8a6830)',border:'none',borderRadius:22,fontSize:14,fontWeight:700,color:'#fff',cursor:'pointer',boxShadow:'0 4px 16px rgba(180,140,80,0.3)',textAlign:'center'}}>💜 인연 찾기</button>
          <button onClick={function(){setCatNavLoading('result');setTimeout(function(){setCatNavLoading(null);setResultTab(0);setPhase('result');},1200);}} style={{width:'100%',padding:'13px 18px',background:'linear-gradient(135deg,#b48c50,#8a6830)',border:'none',borderRadius:22,fontSize:14,fontWeight:700,color:'#fff',cursor:'pointer',boxShadow:'0 4px 16px rgba(180,140,80,0.3)',textAlign:'center'}}>📋 무료 사주 결과</button>
          <button onClick={function(){setCatNavLoading('new');setTimeout(function(){setCatNavLoading(null);setPhase('intro');setIntroStep(0);setResult(null);setPremium(null);setAiCache({});setDialogStep(0);setDialogMsgs([]);setResultTab(0);},1200);}} style={{width:'100%',padding:'13px 18px',background:'linear-gradient(135deg,#b48c50,#8a6830)',border:'none',borderRadius:22,fontSize:14,fontWeight:700,color:'#fff',cursor:'pointer',boxShadow:'0 4px 16px rgba(180,140,80,0.3)',textAlign:'center'}}>🔄 다른 사주 보기</button>
        </div>
      )}

      <style>{'svg{border:none!important;outline:none!important;box-shadow:none!important}@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}@keyframes float1{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}@keyframes float2{0%,100%{transform:translateY(0) translateX(0)}50%{transform:translateY(-15px) translateX(8px)}}@keyframes shimmer{0%{opacity:0.4}50%{opacity:0.8}100%{opacity:0.4}}'}</style>
    </div>
  );

  // ============================================================
  // 인연찾기 — 프로필 선택 화면
  // ============================================================
  if(phase==='matches')return(
    <div style={{minHeight:'100vh',background:'radial-gradient(ellipse at 50% 15%,#1a1028,#0e0a18)',color:'#e8d5a8',fontFamily:"'Noto Sans KR',sans-serif",padding:'20px 16px 60px',maxWidth:440,margin:'0 auto'}}>
      <div style={{textAlign:'center',marginBottom:20}}>
        <BariMansin size={50}/>
        <h2 style={{fontSize:16,fontWeight:700,fontFamily:"'Noto Serif KR',serif",margin:'8px 0'}}><span style={{background:'linear-gradient(135deg,#d0b0ff,#8060c0)',WebkitBackgroundClip:'text',WebkitTextFillColor:'transparent'}}>바리만신이 점지한 인연</span></h2>
        <p style={{fontSize:11,color:'#8070a0'}}>{result.일간}{result.일지}일주({form.gender})에게 어울리는 인연 3명</p>
      </div>

      {yeoninMatches.map(function(u,i){
        var gc=i===0?'#d0a0ff':i===1?'#a0c0ff':'#f0b0c0';
        var rankLabel=i===0?'💜 천생연분':i===1?'💙 편안한 인연':'💗 설레는 인연';
        return(
          <div key={u.key} style={{background:'rgba(160,120,200,0.04)',border:'1px solid rgba(160,120,200,0.12)',borderRadius:16,padding:'16px',marginBottom:12,cursor:'pointer',transition:'all 0.2s'}} onClick={function(){setChatTarget(u);setChatMsgs(function(prev){var k=u.key;if(!prev[k]||prev[k].length===0){var g={from:u.key,text:'안녕하세요! 궁합이 좋다고 해서 기대하고 있었어요 ㅎㅎ',time:'',role:'assistant',content:''};var n=Object.assign({},prev);n[k]=[g];return n;}return prev;});setPhase('chat');}}>
            <div style={{display:'flex',alignItems:'center',gap:4,marginBottom:10}}>
              <span style={{fontSize:11,fontWeight:700,color:gc}}>{rankLabel}</span>
              <span style={{marginLeft:'auto',fontSize:20,fontWeight:800,color:gc}}>{u.matchScore}<span style={{fontSize:11,fontWeight:400}}>점</span></span>
            </div>
            <div style={{display:'flex',gap:14,alignItems:'center'}}>
              <div style={{fontSize:36,width:54,height:54,borderRadius:27,background:'linear-gradient(135deg,rgba(160,120,200,0.15),rgba(160,120,200,0.05))',display:'flex',alignItems:'center',justifyContent:'center',border:'1px solid rgba(160,120,200,0.15)',flexShrink:0}}>{u.emoji}</div>
              <div style={{flex:1}}>
                <div style={{display:'flex',alignItems:'baseline',gap:6}}>
                  <span style={{fontSize:16,fontWeight:700,color:'#e0d0f0'}}>{u.name}</span>
                  <span style={{fontSize:11,color:'#8070a0'}}>{u.age}세 · {u.ilju}일주</span>
                </div>
                <div style={{fontSize:11,color:'#a098b8',marginTop:4,lineHeight:1.6}}>{u.bio}</div>
                <div style={{fontSize:10,color:'#6a5e8d',marginTop:4}}>{u.personality}</div>
              </div>
            </div>
            <div style={{marginTop:10,padding:'8px 12px',background:'rgba(160,120,200,0.06)',borderRadius:8,fontSize:11,color:'#b0a8d0',lineHeight:1.6}}>
              <span style={{fontWeight:600,color:'#8060c0'}}>🔮 바리만신曰:</span> {u.matchComment}
            </div>
            <div style={{textAlign:'center',marginTop:10}}>
              <span style={{fontSize:12,fontWeight:600,color:'#a090d0'}}>대화하기 →</span>
            </div>
          </div>
        );
      })}

      <button onClick={function(){setPhase('premium');}} style={{width:'100%',marginTop:12,background:'transparent',border:'1px solid rgba(160,120,200,0.15)',borderRadius:8,padding:'10px',fontSize:12,color:'#6050a0',cursor:'pointer'}}>사주 분석으로 돌아가기</button>
    </div>
  );

  // ============================================================
  // 인연찾기 — 1:1 채팅 화면
  // ============================================================
  if(phase==='chat'&&chatTarget)return(
    <div style={{minHeight:'100vh',background:'radial-gradient(ellipse at 50% 15%,#1a1028,#0e0a18)',color:'#e8d5a8',fontFamily:"'Noto Sans KR',sans-serif",display:'flex',flexDirection:'column',maxWidth:440,margin:'0 auto'}}>
      {/* 헤더 */}
      <div style={{display:'flex',alignItems:'center',gap:10,padding:'12px 16px',borderBottom:'1px solid rgba(160,120,200,0.1)',background:'rgba(160,120,200,0.04)'}}>
        <button onClick={function(){setPhase('matches');setChatTarget(null);}} style={{background:'transparent',border:'none',color:'#a090d0',fontSize:18,cursor:'pointer',padding:0}}>←</button>
        <div style={{fontSize:24,width:36,height:36,borderRadius:18,background:'linear-gradient(135deg,rgba(160,120,200,0.15),rgba(160,120,200,0.05))',display:'flex',alignItems:'center',justifyContent:'center',border:'1px solid rgba(160,120,200,0.1)'}}>{chatTarget.emoji}</div>
        <div style={{flex:1}}>
          <div style={{fontSize:14,fontWeight:700,color:'#e0d0f0'}}>{chatTarget.name}</div>
          <div style={{fontSize:10,color:'#6050a0'}}>{chatTarget.ilju}일주 · {chatTarget.matchGrade} {chatTarget.matchScore}점</div>
        </div>
      </div>

      {/* 메시지 영역 */}
      <div style={{flex:1,overflowY:'auto',padding:'12px 16px',display:'flex',flexDirection:'column',gap:6,minHeight:300}}>
        <div style={{textAlign:'center',padding:'12px',marginBottom:8}}>
          <div style={{fontSize:10,color:'#6050a0'}}>바리만신이 점지한 인연 · {chatTarget.matchReason}</div>
        </div>
        {(chatMsgs[chatTarget.key]||[]).map(function(msg,i){
          var isMe=msg.from==='me';
          return(
            <div key={i} style={{display:'flex',justifyContent:isMe?'flex-end':'flex-start',gap:6,alignItems:'flex-end'}}>
              {!isMe&&<div style={{fontSize:18,flexShrink:0}}>{chatTarget.emoji}</div>}
              <div style={{maxWidth:'75%',padding:'8px 12px',borderRadius:isMe?'12px 12px 0 12px':'12px 12px 12px 0',background:isMe?'linear-gradient(135deg,#5030a0,#3020a0)':'rgba(160,120,200,0.08)',border:isMe?'none':'1px solid rgba(160,120,200,0.1)'}}>
                <div style={{fontSize:13,lineHeight:1.6,color:isMe?'#fff':'#c0b8d0',whiteSpace:'pre-line'}}>{msg.text}</div>
              </div>
            </div>
          );
        })}
        {yChatLoading&&(
          <div style={{display:'flex',gap:6,alignItems:'flex-end'}}>
            <div style={{fontSize:18}}>{chatTarget.emoji}</div>
            <div style={{padding:'10px 16px',borderRadius:'12px 12px 12px 0',background:'rgba(160,120,200,0.08)',border:'1px solid rgba(160,120,200,0.1)'}}>
              <div style={{display:'flex',gap:4}}>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0s infinite'}}/>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0.2s infinite'}}/>
                <span style={{width:6,height:6,borderRadius:3,background:'#8070a0',animation:'dotPulse 1.2s 0.4s infinite'}}/>
              </div>
            </div>
          </div>
        )}
        <div ref={yChatEndRef}/>
      </div>

      {/* 입력 */}
      <div style={{display:'flex',gap:8,padding:'12px 16px',borderTop:'1px solid rgba(160,120,200,0.1)',background:'rgba(160,120,200,0.02)'}}>
        <input value={chatInput} onChange={function(e){setChatInput(e.target.value);}} onKeyDown={function(e){if(e.key==='Enter')doSend();}} placeholder="메시지를 입력하세요..." style={{flex:1,padding:'10px 14px',borderRadius:20,border:'1px solid rgba(160,120,200,0.2)',background:'rgba(160,120,200,0.04)',color:'#d0b0ff',fontSize:13,outline:'none'}}/>
        <button onClick={doSend} disabled={yChatLoading} style={{padding:'10px 16px',borderRadius:20,border:'none',background:chatInput.trim()&&!yChatLoading?'linear-gradient(135deg,#8060c0,#5030a0)':'rgba(160,120,200,0.1)',color:chatInput.trim()&&!yChatLoading?'#fff':'#6050a0',fontSize:13,fontWeight:700,cursor:'pointer'}}>전송</button>
      </div>
    </div>
  );

  return null;
}
